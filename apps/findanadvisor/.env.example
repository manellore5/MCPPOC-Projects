# findanadvisor — environment variables
# Copy this file to `.env` in the same directory and fill in real values.
# `.env` is gitignored; `.env.example` is committed.

# ─── Required for `npm run nanobot` ─────────────────────────────────────────
# Anthropic API key used by the Nanobot chat agent (Claude Sonnet).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Optional overrides ─────────────────────────────────────────────────────
# MCP-UI iframe URL returned by the `show_advisor_form` tool.
# Defaults to http://localhost:5173?embedded=1 when unset.
# FINDANADVISOR_FORM_URL=

# Fastify REST API port. Defaults to 3000.
# FINDANADVISOR_API_PORT=

# Vite dev server port. Defaults to 5173.
# FINDANADVISOR_CLIENT_PORT=
